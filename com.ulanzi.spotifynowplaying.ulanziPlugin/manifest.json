{
  "Version": "0.1.0",
  "Author": "JoaoV4C",
  "Name": "Spotify Now Playing",
  "Description": "Exibe a faixa atual do Spotify (capa + título) e controla o playback direto do Ulanzi Deck.",
  "Icon": "assets/icons/pluginIcon.png",
  "Category": "Spotify Now Playing",
  "CategoryIcon": "assets/icons/category.png",
  "CodePath": "plugin/app.js",
  "Type": "JavaScript",
  "PrivateAPI": false,
  "SupportedInMultiActions": false,
  "UUID": "com.ulanzi.ulanzistudio.spotifynowplaying",
  "Actions": [
    {
      "Name": "Now Playing",
      "Icon": "assets/icons/spotifyLogo.png",
      "PropertyInspectorPath": "property-inspector/nowPlaying/inspector.html",
      "Tooltip": "Mostra a capa e o título da faixa atual. Aperte para abrir o Spotify.",
      "UUID": "com.ulanzi.ulanzistudio.spotifynowplaying.nowPlaying",
      "Controllers": ["Keypad"],
      "States": [
        { "Image": "assets/icons/spotifyLogo.png" }
      ],
      "SupportedInMultiActions": false
    },
    {
      "Name": "Now Playing (Mosaico 2x2)",
      "Icon": "assets/icons/mosaic.png",
      "PropertyInspectorPath": "property-inspector/mosaic/inspector.html",
      "Tooltip": "Um quadrante da capa. Use 4 teclas 2x2 para formar a imagem completa.",
      "UUID": "com.ulanzi.ulanzistudio.spotifynowplaying.mosaic",
      "Controllers": ["Keypad"],
      "States": [
        { "Image": "assets/icons/mosaic.png" }
      ],
      "SupportedInMultiActions": false
    },
    {
      "Name": "Play / Pause",
      "Icon": "assets/icons/playPause.png",
      "PropertyInspectorPath": "property-inspector/status/inspector.html",
      "Tooltip": "Alterna entre tocar e pausar.",
      "UUID": "com.ulanzi.ulanzistudio.spotifynowplaying.playPause",
      "Controllers": ["Keypad"],
      "States": [
        { "Image": "assets/icons/play.png" },
        { "Image": "assets/icons/pause.png" }
      ],
      "SupportedInMultiActions": false
    },
    {
      "Name": "Próxima faixa",
      "Icon": "assets/icons/next.png",
      "PropertyInspectorPath": "property-inspector/status/inspector.html",
      "Tooltip": "Pula para a próxima faixa.",
      "UUID": "com.ulanzi.ulanzistudio.spotifynowplaying.nextTrack",
      "Controllers": ["Keypad"],
      "States": [
        { "Image": "assets/icons/next.png" }
      ],
      "SupportedInMultiActions": true
    },
    {
      "Name": "Faixa anterior",
      "Icon": "assets/icons/prev.png",
      "PropertyInspectorPath": "property-inspector/status/inspector.html",
      "Tooltip": "Volta para a faixa anterior.",
      "UUID": "com.ulanzi.ulanzistudio.spotifynowplaying.prevTrack",
      "Controllers": ["Keypad"],
      "States": [
        { "Image": "assets/icons/prev.png" }
      ],
      "SupportedInMultiActions": true
    },
    {
      "Name": "Volume (dial)",
      "Icon": "assets/icons/volume.png",
      "PropertyInspectorPath": "property-inspector/volume/inspector.html",
      "Tooltip": "Ajusta o volume com o dial. Pressione para mutar.",
      "UUID": "com.ulanzi.ulanzistudio.spotifynowplaying.volumeDial",
      "Controllers": ["Encoder"],
      "States": [
        { "Image": "assets/icons/volume.png" }
      ],
      "SupportedInMultiActions": false
    },
    {
      "Name": "Aumentar volume",
      "Icon": "assets/icons/volumeUp.png",
      "PropertyInspectorPath": "property-inspector/status/inspector.html",
      "Tooltip": "Aumenta o volume em 10%.",
      "UUID": "com.ulanzi.ulanzistudio.spotifynowplaying.volumeUp",
      "Controllers": ["Keypad"],
      "States": [
        { "Image": "assets/icons/volumeUp.png" }
      ],
      "SupportedInMultiActions": true
    },
    {
      "Name": "Diminuir volume",
      "Icon": "assets/icons/volumeDown.png",
      "PropertyInspectorPath": "property-inspector/status/inspector.html",
      "Tooltip": "Diminui o volume em 10%.",
      "UUID": "com.ulanzi.ulanzistudio.spotifynowplaying.volumeDown",
      "Controllers": ["Keypad"],
      "States": [
        { "Image": "assets/icons/volumeDown.png" }
      ],
      "SupportedInMultiActions": true
    },
    {
      "Name": "Curtir",
      "Icon": "assets/icons/likeAdd.png",
      "PropertyInspectorPath": "property-inspector/status/inspector.html",
      "Tooltip": "Curte ou descurte a faixa atual. Mostra ✓ quando já curtida.",
      "UUID": "com.ulanzi.ulanzistudio.spotifynowplaying.like",
      "Controllers": ["Keypad"],
      "States": [
        { "Image": "assets/icons/likeAdd.png" },
        { "Image": "assets/icons/like.png" }
      ],
      "SupportedInMultiActions": false
    },
    {
      "Name": "Playlist",
      "Icon": "assets/icons/playlist.png",
      "PropertyInspectorPath": "property-inspector/playlist/inspector.html",
      "Tooltip": "Atalho para tocar uma playlist. Mostra a capa e o nome.",
      "UUID": "com.ulanzi.ulanzistudio.spotifynowplaying.playlist",
      "Controllers": ["Keypad"],
      "States": [
        { "Image": "assets/icons/playlist.png" }
      ],
      "SupportedInMultiActions": false
    },
    {
      "Name": "Aleatório",
      "Icon": "assets/icons/shuffle.png",
      "PropertyInspectorPath": "property-inspector/status/inspector.html",
      "Tooltip": "Liga/desliga o modo aleatório. O ícone mostra o estado atual.",
      "UUID": "com.ulanzi.ulanzistudio.spotifynowplaying.shuffle",
      "Controllers": ["Keypad"],
      "States": [
        { "Image": "assets/icons/shuffle.png" },
        { "Image": "assets/icons/shuffleOn.png" }
      ],
      "SupportedInMultiActions": true
    },
    {
      "Name": "Repetir",
      "Icon": "assets/icons/repeat.png",
      "PropertyInspectorPath": "property-inspector/status/inspector.html",
      "Tooltip": "Alterna a repetição: desligado → repetir tudo → repetir a faixa.",
      "UUID": "com.ulanzi.ulanzistudio.spotifynowplaying.repeat",
      "Controllers": ["Keypad"],
      "States": [
        { "Image": "assets/icons/repeat.png" },
        { "Image": "assets/icons/repeatOn.png" },
        { "Image": "assets/icons/repeatTrack.png" }
      ],
      "SupportedInMultiActions": true
    },
    {
      "Name": "Mudo",
      "Icon": "assets/icons/mute.png",
      "PropertyInspectorPath": "property-inspector/status/inspector.html",
      "Tooltip": "Silencia o Spotify; aperte de novo para restaurar o volume anterior.",
      "UUID": "com.ulanzi.ulanzistudio.spotifynowplaying.mute",
      "Controllers": ["Keypad"],
      "States": [
        { "Image": "assets/icons/mute.png" },
        { "Image": "assets/icons/muteOn.png" }
      ],
      "SupportedInMultiActions": true
    }
  ],
  "OS": [
    { "Platform": "windows", "MinimumVersion": "10" },
    { "Platform": "mac", "MinimumVersion": "10.11" }
  ],
  "Software": {
    "MinVersion": "3.0.11"
  }
}
